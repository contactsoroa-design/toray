{
  "version": 2,
  "description": "Golden cases for ToRay billing screenshot classification + OCR.",
  "baseUrlEnv": "BILLING_EVAL_BASE_URL",
  "defaultBaseUrl": "http://localhost:3000",
  "cases": [
    {
      "id": "openai-platform-total",
      "file": "fixtures/openai-platform-total.png",
      "notes": "Synthetic OpenAI Platform usage/billing screen with period total.",
      "expect": {
        "accept": true,
        "service": "OpenAI",
        "amountUsd": 142.5,
        "amountTolerance": 0.05,
        "allowedConfidence": ["high", "medium"]
      }
    },
    {
      "id": "openai-cost-page-variant",
      "file": "fixtures/openai-cost-page-variant.png",
      "notes": "OpenAI Usage/Costs layout variant.",
      "expect": {
        "accept": true,
        "service": "OpenAI",
        "amountUsd": 63.18,
        "amountTolerance": 0.05,
        "allowedConfidence": ["high", "medium"]
      }
    },
    {
      "id": "anthropic-console-total",
      "file": "fixtures/anthropic-console-total.png",
      "notes": "Synthetic Anthropic Console usage/billing screen with period total.",
      "expect": {
        "accept": true,
        "service": "Anthropic",
        "amountUsd": 87.4,
        "amountTolerance": 0.05,
        "allowedConfidence": ["high", "medium"]
      }
    },
    {
      "id": "gemini-ai-studio-total",
      "file": "fixtures/gemini-ai-studio-total.png",
      "notes": "Gemini AI Studio — Pro Vision. Eval with BILLING_EVAL_ALLOW_FOUNDING=1.",
      "expect": {
        "accept": true,
        "service": "Gemini",
        "amountUsd": 64.2,
        "amountTolerance": 0.05,
        "allowedConfidence": ["high", "medium"],
        "requiresFounding": true
      }
    },
    {
      "id": "grok-xai-console-total",
      "file": "fixtures/grok-xai-console-total.png",
      "notes": "xAI / Grok API console — Pro Vision.",
      "expect": {
        "accept": true,
        "service": "Grok",
        "amountUsd": 51.75,
        "amountTolerance": 0.05,
        "allowedConfidence": ["high", "medium"],
        "requiresFounding": true
      }
    },
    {
      "id": "cursor-usage-total",
      "file": "fixtures/cursor-usage-total.png",
      "notes": "Cursor billing/usage — Pro Vision.",
      "expect": {
        "accept": true,
        "service": "Cursor",
        "amountUsd": 38.9,
        "amountTolerance": 0.05,
        "allowedConfidence": ["high", "medium"],
        "requiresFounding": true
      }
    },
    {
      "id": "copilot-billing-total",
      "file": "fixtures/copilot-billing-total.png",
      "notes": "GitHub Copilot billing — Pro Vision.",
      "expect": {
        "accept": true,
        "service": "Copilot",
        "amountUsd": 29,
        "amountTolerance": 0.05,
        "allowedConfidence": ["high", "medium"],
        "requiresFounding": true
      }
    },
    {
      "id": "openai-jpy-reject",
      "file": "fixtures/openai-jpy-reject.png",
      "notes": "OpenAI chrome but JPY total — must reject (USD only).",
      "expect": {
        "accept": false
      }
    },
    {
      "id": "openai-credits-only-reject",
      "file": "fixtures/openai-credits-only-reject.png",
      "notes": "Credits remaining without period total — must reject.",
      "expect": {
        "accept": false
      }
    },
    {
      "id": "chatgpt-plus-settings",
      "file": "fixtures/chatgpt-plus-settings.png",
      "notes": "ChatGPT consumer subscription settings — must NOT classify as OpenAI Platform.",
      "expect": {
        "accept": false
      }
    },
    {
      "id": "random-landscape",
      "file": "fixtures/random-landscape.png",
      "notes": "Unrelated photo with a dollar string — must reject.",
      "expect": {
        "accept": false
      }
    },
    {
      "id": "stripe-receipt",
      "file": "fixtures/stripe-receipt.png",
      "notes": "Generic payment receipt — must reject.",
      "expect": {
        "accept": false
      }
    },
    {
      "id": "midjourney-plan",
      "file": "fixtures/midjourney-plan.png",
      "notes": "Other SaaS billing UI — must reject.",
      "expect": {
        "accept": false
      }
    }
  ]
}
